{
  "name": "vite-react-typescript-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "node server/index.mjs",
    "verify:assistant": "node scripts/verify-assistant.mjs",
    "verify:cloud-sync": "node scripts/verify-cloud-sync.mjs",
    "generate:icons": "node scripts/generate-icons.mjs",
    "build": "vite build",
    "build:capacitor": "vite build --mode capacitor",
    "build:ios": "npm run build:capacitor && npx cap sync ios",
    "cap:sync": "npm run build:capacitor && npx cap sync",
    "cap:sync:ios": "npm run build:capacitor && npx cap sync ios",
    "cap:open:ios": "npx cap open ios",
    "cap:copy:ios": "npx cap copy ios",
    "lint": "eslint .",
    "preview": "vite preview",
    "screenshot:lovequest": "node scripts/screenshot-lovequest.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.app.json"
  },
  "dependencies": {
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/ios": "^8.3.4",
    "@supabase/supabase-js": "^2.57.4",
    "dotenv": "^16.4.7",
    "html-to-image": "^1.11.13",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.344.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^9.1.2",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "playwright": "^1.52.0",
    "postcss": "^8.4.35",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2"
  }
}
