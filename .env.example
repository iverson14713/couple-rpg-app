# --- Server only (Node assistant API). Load from project root `.env` via dotenv.
# Do NOT use VITE_ prefix — these must never be bundled into the React client.
# On Vercel: set the same names in Project → Environment Variables (not in the repo).

OPENAI_API_KEY=
# Default in server: gpt-4o-mini. Override with any chat model your key supports.
OPENAI_MODEL=gpt-4o-mini

# Port for server/index.mjs (must match Vite proxy target unless you override)
ASSISTANT_SERVER_PORT=8788

# Optional: Vite dev proxy target (defaults to http://127.0.0.1:8788)
# ASSISTANT_SERVER_URL=http://127.0.0.1:8788

# Optional: couple RPG AI client dev base (defaults to http://127.0.0.1:8788 on localhost)
# VITE_ASSISTANT_SERVER_URL=http://127.0.0.1:8788
#
# Capacitor iOS/Android: WebView origin is local https://lovequest.app — `/api/*` must hit Vercel.
# If unset, native builds default to https://couple-rpg-app.vercel.app
# VITE_LOVEQUEST_API_ORIGIN=https://couple-rpg-app.vercel.app

# --- Supabase (Vite client; safe to expose anon key in browser)
# Create a project at https://supabase.com — URL and anon key are in Project Settings → API.
# Apply SQL migrations under supabase/migrations/ (e.g. profiles table) before using auth.
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=
# Apple OAuth — iOS 上架必設（見 docs/apple-sign-in-setup.md）
# 建議放在 .env 或 .env.capacitor（npm run build:capacitor）
# VITE_APPLE_OAUTH_ENABLED=true
#
# Supabase Dashboard → Authentication → URL Configuration:
#   Site URL: https://your-production-domain (e.g. Vercel deployment)
#   Redirect URLs (add each origin):
#     https://your-production-domain/auth/callback
#     http://localhost:5173/auth/callback
# Email templates use the same /auth/callback for confirmation links.
# Server-only: verify JWT + write lovequest_ai_daily_usage (never expose in client)
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
# Optional: for `npm run verify:cloud-sync` (RLS live table tests)
# SUPABASE_TEST_EMAIL=
# SUPABASE_TEST_PASSWORD=

# --- AI cost / abuse protection (server/index.mjs + server/guard.mjs)
# Comma-separated client IDs (from browser localStorage cat-ai-client-id) that get Pro daily quota.
# AI_PRO_CLIENT_IDS=
# When set to 1/true, the assistant API honors `plan: "pro"` from the client body/query for daily quota
# (for staging/production test builds). In local dev (NODE_ENV !== production) this is always on.
# AI_TRUST_CLIENT_PLAN=1
# AI_FREE_DAILY_LIMIT=3
# AI_PRO_DAILY_LIMIT=30
# Optional rough USD estimate per 1M tokens for usage.jsonl (set both to log estUsd)
# AI_EST_INPUT_PER_1M_USD=0.15
# AI_EST_OUTPUT_PER_1M_USD=0.60
