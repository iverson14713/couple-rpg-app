# Capacitor iOS/Android 本機包（npm run build:ios）
# 開發用 UI（僅 vite dev + true）；上架 / build:ios 必須 false
VITE_LOVEQUEST_DEBUG_NOTIFICATIONS=false
# WebView 為 https://lovequest.app，/api/* 必須打 Vercel（與 AI assistant 相同）
VITE_LOVEQUEST_API_ORIGIN=https://couple-rpg-app.vercel.app
# Apple 登入（Supabase Auth → Providers → Apple；Redirect: lovequest://auth/callback）
VITE_APPLE_OAUTH_ENABLED=true
